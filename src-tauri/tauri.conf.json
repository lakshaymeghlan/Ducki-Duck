{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ducki-duck",
  "version": "0.1.0",
  "identifier": "com.duckiduck.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3030",
    "beforeDevCommand": "npm run dev -- -p 3030",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "pet",
        "url": "pet",
        "title": "ducki-duck",
        "width": 132,
        "height": 148,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
